	public int getStreakGoal() {
		Scanner scanner = new Scanner(System.in);
		
		System.out.println("input your number :");
		int n = scanner.nextInt();
		int sum = 0;
		for (int i =1 ; i<=n ; i++) {
			sum+=i ;
		}
		scanner.close(); 
		return sum;
		
	}
	}

